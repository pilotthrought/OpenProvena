{
  "title": "OpenProvena — Vue d'ensemble",
  "uid": "openprovena-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requêtes HTTP / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"openprovena_api\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latence p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"openprovena_api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Taux d'erreur 5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"openprovena_api\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "API — Up/Down",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "up{job=\"openprovena_api\"}" }
      ]
    }
  ]
}
